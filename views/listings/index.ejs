<% layout("/layouts/boilerplate") -%>

<style>
  /* Filters Section Styles */
  #filters {
    display: flex;
    align-items: center;
    overflow-x: auto;
    white-space: nowrap;
    padding-bottom: 0.5rem;
  }
  #filters::-webkit-scrollbar { display: none; }
  #filters { -ms-overflow-style: none; scrollbar-width: none; }

  .filter {
    text-align: center;
    margin-right: 2rem;
    opacity: 0.7;
    transition: opacity 0.2s ease, border-bottom 0.2s ease;
    display: inline-block;
    padding-bottom: 4px;
  }
  .filter:hover { opacity: 1; cursor: pointer; border-bottom: 2px solid #000; }
  .filter p { font-size: 0.8rem; }
  
  .tax-info { display: none; }
  .tax-toggle {
    border: 1px solid rgb(58, 56, 56);
    border-radius: 12px;
    padding: 0.5rem 1rem;
    margin-left: auto;
    opacity: 0.7;
  }
  .tax-toggle:hover { opacity: 1; }

  /* Animation for Empty State */
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }
  .animate-float { animation: float 3s ease-in-out infinite; }
</style>

<div id="filters" class="mt-4">
  <% let categories = ["Trending", "Rooms", "Iconic Cities", "Mountains", "Castles", "Camping", "Farms", "Arctic", "Amezing Pools", "Boats", "Domes"]; %>
  <% let icons = ["fire", "bed", "mountain-city", "mountain", "fort-awesome", "campground", "cow", "snowflake", "person-swimming", "ship", "igloo"]; %>
  
  <% for(let i=0; i<categories.length; i++) { %>
    <div class="filter" data-category="<%= categories[i] %>">
      <i class="fa-solid fa-<%= icons[i] %>"></i>
      <p class="mb-0"><%= categories[i] %></p>
    </div>
  <% } %>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
      <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div> 
<div class="row">
  <% if (allListing.length === 0) { %>
    <div class="col-12 mt-5">
      <div class="d-flex flex-column justify-content-center align-items-center text-center">
        <div class="animate-float" style="max-width: 300px; width: 100%;">
          <img src="https://cdni.iconscout.com/illustration/premium/thumb/no-data-found-8865737-7265556.png" 
               alt="No results" style="width: 100%; height: auto;">
        </div>
        <h3 class="mt-4 text-secondary">No matches found</h3>
        <p class="text-muted">Try adjusting your filters or search criteria.</p>
        <a href="/listings" class="btn btn-dark mt-2 px-4">Clear all filters</a>
      </div>
    </div>
  <% } %>
</div>
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mt-3">
   <% if (allListing.length !== 0) { %>
    <% for(let listing of allListing){ %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card h-100">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" style="height: 20rem; object-fit: cover;">
            <div class="card-body">
              <p class="card-title fw-semibold"><%= listing.title %></p>
              <p>₹<%= listing.price.toLocaleString('en-IN') %> / night
              <i class="tax-info"> &nbsp; &nbsp; +18% GST </i></p>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  <% } %>
</div>

<script>
  // Tax Toggle Logic
  let taxSwitch = document.getElementById("flexSwitchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(let info of taxInfo) {
      info.style.display = (info.style.display != "inline") ? "inline" : "none";
    }
  });

  // Filter Click Logic
  const filters = document.querySelectorAll(".filter");
  filters.forEach(filter => {
    filter.addEventListener("click", () => {
      const category = filter.getAttribute("data-category");
      const currentUrlParams = new URLSearchParams(window.location.search);
      currentUrlParams.set("category", category);
      window.location.href = `/listings?${currentUrlParams.toString()}`;
    });
  });
</script>