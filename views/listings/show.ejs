<% layout("/layouts/boilerplate") -%>

<body>
  <div class="container my-5">
    <div class="row justify-content-center">
      <div class="col-12 col-md-11 col-lg-10">
        <h3 class="fw-bold mb-4 text-dark text-start"><%= listing.title %></h3>
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white mb-4">
          <img src="<%= listing.image.url %>" class="img-fluid w-100" alt="<%= listing.title %>" style="max-height: 420px; object-fit: cover;">
          <div class="card-body p-4 text-start">
            <p class="card-text">Owned by <i><%= listing.owner.username %></i></p>
            <h2 class="fw-bold text-dark mb-2">Place Details</h2>
            <p class="text-muted small mb-3">
              <i class="bi bi-geo-alt-fill text-danger me-1"></i>
              <%= listing.location %>, <%= listing.country %>
            </p>
            <h4 class="fw-bold text-danger mb-3">
              &#8377;<%= listing.price.toLocaleString('en-IN') %> <span class="fs-6 fw-normal text-muted">/ night</span>
            </h4>
            <hr class="text-muted my-3">
            <h5 class="fw-bold text-dark mb-2">About this space</h5>
            <p class="text-secondary lh-lg mb-4"><%= listing.description %></p>
            <hr class="text-muted my-4">
            <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
              <div class="d-flex gap-3 flex-wrap">
                <a class="btn btn-dark px-4 rounded-3 fw-semibold shadow-sm d-inline-flex align-items-center" href="/listings/<%= listing._id %>/edit">Edit Details</a>
                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
                  <button type="submit" class="btn btn-danger px-4 rounded-3 fw-semibold shadow-sm">Delete Listing</button>
                </form>
              </div>
            <% } %>
            <hr class="my-4">
            <% if (currUser) { %>
              <div>
                <h4 class="fw-bold text-dark mb-3">Leave a Review</h4>
                <form action="/listings/<%= listing._id %>/reviews" method="post" class="needs-validation" novalidate>
                  <div class="my-3">
                    <label class="form-label fw-medium d-block">Rating</label>
                    <fieldset class="starability-growRotate">
                      <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" aria-label="No rating." checked />
                      <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                      <label for="first-rate1" title="Terrible">1 star</label>
                      <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                      <label for="first-rate2" title="Not good">2 stars</label>
                      <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                      <label for="first-rate3" title="Average">3 stars</label>
                      <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                      <label for="first-rate4" title="Very good">4 stars</label>
                      <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                      <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                  </div>
                  <div class="mb-3">
                    <label for="comment" class="form-label fw-medium">Comment</label>
                    <textarea name="review[comment]" id="comment" class="form-control" rows="3" required></textarea>
                    <div class="invalid-feedback">Please add a valid comment!</div>
                  </div>
                  <div>
                    <button type="submit" class="btn btn-outline-dark px-4 rounded-3 fw-semibold shadow-sm">Submit Review</button>
                  </div>
                </form>
              </div>
            <% } %>
          </div>
        </div>
        <h4 class="fw-bold mb-4">Reviews</h4>
        <div class="row row-cols-1 row-cols-md-2 g-4">
          <% for(let review of listing.reviews) { %>
            <div class="col">
              <div class="card h-100 border-0 shadow-sm p-3 rounded-3">
                <div class="card-body">
                  <h6 class="card-title fw-bold mb-2 text-dark">@<%= review.author.username %></h6>
                  <div class="mb-2 text-warning">
                    <% for(let j = 1; j <= 5; j++) { %>
                      <i class="<%= j <= review.rating ? 'fa-solid' : 'fa-regular' %> fa-star small"></i>
                    <% } %>
                  </div>
                  <p class="card-text text-secondary mb-3"><%= review.comment %></p>
                  <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                      <button class="btn btn-sm btn-outline-danger border-0">Delete</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>