<% layout("/layouts/boilerplate") -%>
<body>
  <div class="container my-5 d-flex justify-content-center align-items-center">
    <div class="row w-100 justify-content-center">
      <div class="col-12 col-md-10 col-lg-8">
        
        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
          
          <div class="card-title text-center mb-4">
            <h2 class="fw-bold text-dark">Edit Listing</h2>
            <p class="text-muted small">Update the details of your property below</p>
          </div>
          
          <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" enctype="multipart/form-data" novalidate>
        
            <div class="mb-3">
              <label for="title" class="form-label fw-semibold">Title</label>
              <input type="text" class="form-control" id="title" name="listing[title]" value="<%= listing.title %>" required>
              <div class="invalid-feedback">Title should be valid</div>
            </div>
        
            <div class="mb-3">
              <label for="description" class="form-label fw-semibold">Description</label>
              <textarea id="description" class="form-control" name="listing[description]" rows="4" required><%= listing.description %></textarea>
              <div class="invalid-feedback">Description should be valid.</div>

            </div>
            <!-- image preview -->
             <div>
              Original listing image <br>
              <img src="<%= originalImageUrl %>" alt="<%= listing.image.filename %>">
             </div>
            <div class="mb-3">
              <label for="image" class="form-label fw-semibold">Upload New image</label>
              <input type="file" class="form-control" id="title" name="listing[image]">
              <div class="invalid-feedback">Image url/link should be valid.</div>
            </div>
            
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label for="price" class="form-label fw-semibold">Price (&#8377;)</label>
                <div class="input-group">
                  <span class="input-group-text">&#8377;</span>
                  <input type="number" class="form-control" id="price" name="listing[price]" value="<%= listing.price %>" min="0" required>
                  <div class="invalid-feedback">Price should be valid.</div>
                </div>
              </div>
              
              <!-- category -->
              <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <select name="listing[category]" id="category" class="form-select" required>
                  <option value="Trending" <%= listing.category === "Trending" ? "selected" : "" %>>Trending</option>
                  <option value="Rooms" <%= listing.category === "Rooms" ? "selected" : "" %>>Rooms</option>
                  <option value="Iconic Cities" <%= listing.category === "Iconic Cities" ? "selected" : "" %>>Iconic Cities</option>
                  <option value="Mountains" <%= listing.category === "Mountains" ? "selected" : "" %>>Mountains</option>
                  <option value="Castles" <%= listing.category === "Castles" ? "selected" : "" %>>Castles</option>
                  <option value="Camping" <%= listing.category === "Camping" ? "selected" : "" %>>Camping</option>
                  <option value="Farms" <%= listing.category === "Farms" ? "selected" : "" %>>Farms</option>
                  <option value="Arctic" <%= listing.category === "Arctic" ? "selected" : "" %>>Arctic</option>
                  <option value="Amezing Pools" <%= listing.category === "Amezing Pools" ? "selected" : "" %>>Amezing Pools</option>
                  <option value="Boats" <%= listing.category === "Boats" ? "selected" : "" %>>Boats</option>
                  <option value="Domes" <%= listing.category === "Domes" ? "selected" : "" %>>Domes</option>
                </select>
              </div>

              <div class="col-md-6">
                <label for="location" class="form-label fw-semibold">Location</label>
                <input type="text" class="form-control" id="location" name="listing[location]" value="<%= listing.location %>" required>
                <div class="invalid-feedback">Location should be valid</div>
              </div>
            </div> 
        
            <div class="mb-4">
              <label for="country" class="form-label fw-semibold">Country</label>
              <input type="text" id="country" class="form-control" name="listing[country]" value="<%= listing.country %>" required>
              <div class="invalid-feedback">country should be valid</div>
            </div>
        
            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-dark btn-lg rounded-3 fw-bold shadow-sm">
                Update Listing
              </button>
              <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary btn-sm border-0 mt-1">
                Cancel & Go Back
              </a>
            </div>
        
          </form>
        </div>
        
      </div>
    </div>
  </div>
</body>